{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marvex",
  "version": "0.3.0",
  "identifier": "com.marvex.shell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Marvex",
        "url": "/",
        "width": 1120,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "Marvex Status",
        "url": "/?surface=overlay",
        "width": 140,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "../../assets/icon.ico"
    ],
    "resources": {
      "../runtime/uv.exe": "uv.exe",
      "../runtime/node.exe": "node.exe",
      "../runtime/playwright-mcp": "playwright-mcp",
      "../runtime/marvex-*.whl": ".",
      "../runtime/wheels": "wheels",
      "../../control_plane_web/dist": "control_plane_web",
      "../../../voice_models.manifest.json": "voice_models.manifest.json",
      "../voice-assets/stt/moonshine-v2": "voice-assets/stt/moonshine-v2",
      "../voice-assets/wakeword/hey-marvex": "voice-assets/wakeword/hey-marvex"
    },
    "windows": {
      "nsis": {
        "installerIcon": "../../assets/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerHooks": "./installer-hooks.nsh"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
